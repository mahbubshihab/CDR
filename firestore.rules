rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the user is an owner email
    function isOwnerEmail() {
      return request.auth.token.email in [
        'cdroreco@gmail.com',
        'xlshihab9@gmail.com'
      ];
    }

    // Helper to check if the user matches the target userId
    function isSelf(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User Profile Rules
    match /users/{userId} {
      // Owners can do anything on user profiles
      allow read, write: if isAuthenticated() && isOwnerEmail();

      // Users can read their own profiles, or any owner profile (to find owner UIDs for notification dispatch)
      allow read: if isSelf(userId) || (isAuthenticated() && resource.data.role == 'owner');
      
      // Users can initially register (create a pending request)
      allow create: if isSelf(userId) && request.resource.data.status == 'pending';
      
      // Users can update their own lastLogin timestamp, but cannot change their status/role
      allow update: if isSelf(userId) && 
                    request.resource.data.status == resource.data.status && 
                    request.resource.data.role == request.resource.data.role;
    }

    // Notifications Sub-collection Rules
    match /users/{userId}/notifications/{notificationId} {
      // Self or Owner can read, update, or delete notifications
      allow read, update, delete: if isSelf(userId) || isOwnerEmail();
      
      // Anyone authenticated can create a notification for a user (needed to send requests to owners/approvals to users)
      allow create: if isAuthenticated();
    }

    // Access limits & expiry collection rules (Write: Owner only, Read: Owner & Self)
    match /limits/{userId} {
      allow read: if isSelf(userId) || isOwnerEmail();
      allow write: if isAuthenticated() && isOwnerEmail();
    }

    // User metrics/usage counters collection rules (Read & Write: Owner & Self)
    match /userStats/{userId} {
      allow read, write: if isSelf(userId) || isOwnerEmail();
    }
  }
}
